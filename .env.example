# ============================================================
# Luanny — Configuração de Credenciais e Parâmetros
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA compartilhe o arquivo .env preenchido.
# ============================================================

# Credenciais do Instagram (conta operacional dedicada)
INSTAGRAM_USERNAME=sua_conta_operacional
INSTAGRAM_PASSWORD=sua_senha

# Parâmetros de coleta (opcionais — valores padrão indicados)
# MAX_POSTS=30
# HEADLESS=true
# CAPTURE_EVIDENCE=true
# BROWSER_LANGUAGE=pt-BR
# NAVIGATION_TIMEOUT=30000
# ELEMENT_TIMEOUT=10000
# DELAY_MIN=3.0
# DELAY_MAX=7.0
# OUTPUT_DIR=data
